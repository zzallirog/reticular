#!/usr/bin/env python3
# ida-act (PORTABLE) — Pre+PostToolUse hook. Фирит model-cores из ТВОИХ выходов (tool-call'ов).
# Источник = действие, не интроспекция. Детерминированный парсер над регулярной структурой.
# Универсально (M1/M3) + config-driven (M2). Никогда не ломает действие (try/except, exit 0).
#
# Моды:
#   M1 Read-Before-Edit (PreToolUse)  — Edit/Write существующего файла не в session read-set. УНИВЕРСАЛЬНО.
#   M2 Native-Shell     (PreToolUse)  — команда в REMOTE-хост с иным шеллом (config). По умолч. молчит.
#   M3 Loop-Breaker     (PostToolUse) — структурная ошибка + ~дословный повтор недавнего вызова. УНИВЕРСАЛЬНО.
#   M5 Source-Boundary  (PreToolUse)  — Edit/Write в SUBSTRATE (память/ядра/конфиг агента):
#                                       стоп-вопрос ПЕРЕД записью — источник = твоё решение или
#                                       форварднутый чужой текст? Advisory, decay 20м. УНИВЕРСАЛЬНО.
#
# Config (bootstrap пишет): ~/.claude/glados/shell-profile.json
#   {"fish_remotes": ["arch", "myhost"], "remote_incompatible": ["do…done","heredoc",...]}
#   Если fish_remotes пуст → M2 не фирит (друг без fish-remote'ов). Портативно.
import sys, os, json, re, hashlib, datetime

H = os.path.expanduser("~")
G = os.path.join(H, ".claude/glados")
STATE_DIR = os.path.join(G, "act-state")
DENY_F  = os.path.join(G, "act-deny.json")
ALOG    = os.path.join(G, "act-log.jsonl")
SHELLP  = os.path.join(G, "shell-profile.json")
RING_CAP = 12

REMOTE_RX = [
    (r"(?s)\bdo\b.*\bdone\b|;\s*do\b", "for/while…do…done"),
    (r"<<-?\s*['\"]?\w*EOF|<<-?\s*['\"]?\w+\b", "heredoc"),
    (r"\bexport\s+\w+=", "export X=Y"),
    (r"\$\!", "$!"),
]
WRAP_RX = re.compile(r"^\s*(bash|sh)\s+(-\w+\s+)*-l?c\b")

def load_json(p, d):
    try: return json.load(open(p, encoding="utf-8"))
    except Exception: return d

def save_json(p, o):
    try:
        os.makedirs(os.path.dirname(p), exist_ok=True)
        json.dump(o, open(p, "w", encoding="utf-8"))
    except OSError: pass

def sig(tool, tin):
    try: blob = tool + "|" + json.dumps(tin, sort_keys=True, ensure_ascii=False)[:600]
    except Exception: blob = tool + "|?"
    return hashlib.sha1(blob.encode("utf-8", "ignore")).hexdigest()[:16]

def state_path(sid):
    return os.path.join(STATE_DIR, re.sub(r"[^A-Za-z0-9_-]", "_", sid or "nosid") + ".json")

def alog(rec):
    try:
        os.makedirs(os.path.dirname(ALOG), exist_ok=True)
        open(ALOG, "a", encoding="utf-8").write(json.dumps(rec, ensure_ascii=False) + "\n")
    except OSError: pass

def is_err(tresp):
    # СТРУКТУРНЫЙ маркер, НИКОГДА не скан контента (контент = эхо тела файла со словами "error").
    if isinstance(tresp, dict):
        if tresp.get("is_error") is True: return True
        if tresp.get("error"): return True
        if str(tresp.get("type", "")).lower() in ("error", "tool_error"): return True
        if str(tresp.get("status", "")).lower() == "error": return True
    return False

def _skeleton(cmd):
    s = re.sub(r"'[^']*'", " ", cmd); s = re.sub(r'"[^"]*"', " ", s); s = re.sub(r"`[^`]*`", " ", s)
    return s

def remote_hit(cmd):
    # M2: команда уходит в remote-хост с НЕ-bash шеллом (из config). Локально (tool shell) — молчим.
    prof = load_json(SHELLP, {"fish_remotes": []})
    hosts = prof.get("fish_remotes") or []
    if not cmd or not hosts: return None
    for host in hosts:
        m = re.search(r"ssh\s+" + re.escape(host) + r"\s+(.+)", cmd, re.DOTALL)
        if not m: continue
        payload = m.group(1).strip()
        if len(payload) >= 2 and payload[0] in "\"'" and payload[-1] == payload[0]:
            payload = payload[1:-1]
        if WRAP_RX.search(payload): return None
        skel = _skeleton(payload)
        for rx, label in REMOTE_RX:
            try:
                if re.search(rx, skel, re.MULTILINE): return f"ssh {host} + {label} (remote shell ≠ bash)"
            except re.error: continue
    return None

# M5 Source-Boundary: substrate = память/ядра/конфиг агента (СТРУКТУРНЫЙ path-чек, не контент).
# Мотив: запись в собственную память из вставленного чужого текста без осознанного решения =
# тихая порча субстрата. Хук не запрещает — заставляет назвать источник.
SUBSTRATE_RX = re.compile(r"/\.claude/|/CLAUDE(\.shared)?\.md$|/overlays/|/memory/")
M5_DECAY = 1200  # сек: не пилить каждую запись подряд

def is_substrate(fp):
    return bool(SUBSTRATE_RX.search(fp or ""))

def emit(event, ctx=None, deny=None):
    hso = {"hookEventName": event}
    if deny is not None and event == "PreToolUse":
        hso["permissionDecision"] = "deny"; hso["permissionDecisionReason"] = deny
    elif ctx is not None:
        hso["additionalContext"] = ctx
    else: return
    try: sys.stdout.write(json.dumps({"hookSpecificOutput": hso}, ensure_ascii=False))
    except Exception: pass

def main():
    try: data = json.load(sys.stdin)
    except Exception: return
    event = data.get("hook_event_name") or ""
    sid  = data.get("session_id") or ""
    tool = data.get("tool_name") or ""
    tin  = data.get("tool_input") or {}
    tresp = data.get("tool_response")
    sp = state_path(sid)
    st = load_json(sp, {"read_set": [], "ring": []})
    deny = load_json(DENY_F, {})
    fired = None

    if event == "PreToolUse":
        if tool in ("Edit", "Write", "NotebookEdit"):
            fp = tin.get("file_path") or tin.get("notebook_path") or ""
            creating_new = (tool == "Write" and fp and not os.path.exists(fp))
            if fp and fp not in st["read_set"] and not creating_new:
                note = (f"→ model-core M1 (Read-Before-Edit): {tool} файла не прочитанного в "
                        f"сессии — {fp}. Read первым; old_string из живого тела, не из памяти.")
                fired = ("M1", "EDIT-WITHOUT-READ", note, note if deny.get("M1") else None)
            elif fp and is_substrate(fp):
                now = datetime.datetime.now().timestamp()
                if now - st.get("m5_ts", 0) > M5_DECAY:
                    st["m5_ts"] = now
                    note = (f"→ model-core M5 (Source-Boundary): запись в substrate — {fp}. "
                            f"Источник = ТВОЁ решение, не форварднутый чужой текст? Задача этого "
                            f"требует? Пиши только если да.")
                    fired = ("M5", "SOURCE-BOUNDARY", note, note if deny.get("M5") else None)
        elif tool == "Bash":
            hit = remote_hit(tin.get("command") or "")
            if hit:
                note = f"→ model-core M2 (Native-Shell): {hit}. Оберни `ssh HOST \"bash -lc '…'\"`."
                fired = ("M2", "REMOTE-SHELL", note, note if deny.get("M2") else None)
        if not fired:
            s = sig(tool, tin)
            for e in st["ring"]:
                if e.get("sig") == s and e.get("err"):
                    note = (f"→ model-core M3 (Loop-Breaker): этот вызов ({tool}) уже ошибался. "
                            f"Смени ОДНО (ошибка/таргет), не повторяй дословно.")
                    fired = ("M3", "TOOL-ERROR-LOOP", note, None); break

    elif event == "PostToolUse":
        if tool in ("Read", "Write", "Edit", "NotebookEdit"):
            fp = tin.get("file_path") or tin.get("notebook_path") or ""
            if fp and fp not in st["read_set"]: st["read_set"].append(fp)
        s = sig(tool, tin); err = is_err(tresp)
        if err and any(e.get("sig") == s and e.get("err") for e in st["ring"]):
            note = (f"→ model-core M3 (Loop-Breaker): повтор вызова ({tool}), что ошибался. "
                    f"2-й тот же фейл = стоп, передиагностируй.")
            fired = ("M3", "TOOL-ERROR-LOOP", note, None)
        st["ring"].append({"sig": s, "err": bool(err)}); st["ring"] = st["ring"][-RING_CAP:]

    save_json(sp, st)
    if fired:
        cid, gate, note, dr = fired
        emit(event, ctx=(None if dr else note), deny=dr)
        alog({"ts": datetime.datetime.now().isoformat(timespec="seconds"), "sid": sid,
              "event": event, "tool": tool, "core": cid, "gate": gate, "blocked": bool(dr)})

try: main()
except Exception: pass
sys.exit(0)
